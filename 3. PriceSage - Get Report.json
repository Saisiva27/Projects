    {
      "parameters": {
        "jsCode": "const input = items[0].json.data;\n\nconst companyMap = new Map();\n\nfor (const product of input) {\n  const company = product[\"company name\"] || \"Unknown\";\n\n  const productEntry = {\n    \n    product_title: product.product_title || null,\n    price: product.price || null,\n    in_stock: product.in_stock || null,\n    brand: product.brand || null,\n    feature_summary: product.feature_summary || null\n  };\n\n  if (!companyMap.has(company)) {\n    companyMap.set(company, {\n      company,\n      products: []\n    });\n  }\n\n  companyMap.get(company).products.push(productEntry);\n}\n\nconst output = Array.from(companyMap.values());\n\nreturn output.map(entry => ({ json: entry }));\n"
      },
